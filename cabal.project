packages: .

tests:      True
benchmarks: True

-- effectful is pinned to 2.6.1.0, the version whose tested-with covers the
-- GHCs in this project's CI matrix (9.6 / 9.8 / 9.10). No freeze file is
-- committed: a library should solve fresh against each supported compiler, so
-- CI lets every matrix entry pick its own consistent dependency set.
constraints:
    effectful      ==2.6.1.0
  , effectful-core ==2.6.1.0
